{
  "name": "project-management-tool",
  "version": "1.0.0",
  "description": "Modern MERN stack project management application",
  "main": "src/server.js",
  "private": true,
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "server": "nodemon src/server.js",
    "client": "npm start --prefix frontend",
    "build": "npm run build --prefix frontend",
    "install-all": "npm install && npm install --prefix frontend"
  },
  "keywords": [
    "mern",
    "project-management",
    "express",
    "mongodb",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.7",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "mongoose": "^8.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
